# ── Backend API ──────────────────────────────────────
# The full URL to the backend API (including /api prefix)
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# ── WebSocket ────────────────────────────────────────
# The backend base URL for Socket.IO connections (no /api suffix)
NEXT_PUBLIC_WS_URL=http://localhost:4000

# ── App URL (optional) ──────────────────────────────
# The public URL of this frontend app, used for metadata/SEO
# NEXT_PUBLIC_APP_URL=http://localhost:3000
