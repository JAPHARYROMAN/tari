# ── Application ─────────────────────────────────────
NODE_ENV=development
PORT=4000
LOG_LEVEL=log

# ── Database ────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/tari?schema=public

# ── Redis ───────────────────────────────────────────
# Use REDIS_URL for managed services (e.g. Render, Railway, Upstash)
# Or use individual REDIS_HOST/PORT/PASSWORD for manual setup
# REDIS_URL takes precedence when set
# REDIS_URL=redis://:password@host:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ─────────────────────────────────────────────
# IMPORTANT: Use strong, unique secrets in production (min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Cloudinary ──────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── CORS / Client ──────────────────────────────────
# CLIENT_URL is the primary frontend origin (used for CORS and redirects)
CLIENT_URL=http://localhost:3000
# Optional: comma-separated additional origins for CORS
# CORS_ALLOWED_ORIGINS=https://tari.example.com,https://staging.tari.example.com
# Optional: cookie domain for cross-subdomain auth (e.g. .example.com)
# COOKIE_DOMAIN=.example.com
